diff --git a/arch/x86/include/asm/futex_robust.h b/arch/x86/include/asm/futex_robust.h
index e87954703ae2..ff3f7aac2d2a 100644
--- a/arch/x86/include/asm/futex_robust.h
+++ b/arch/x86/include/asm/futex_robust.h
@@ -16,4 +16,19 @@ static __always_inline void __user *x86_futex_robust_unlock_get_pop(struct pt_re
 #define arch_futex_robust_unlock_get_pop(regs)	\
 	x86_futex_robust_unlock_get_pop(regs)
 
+static __always_inline void __user *x86_futex_robust_cmpxchg_get_pending(struct pt_regs *regs)
+{
+	/*
+	 * If ZF is clear then the cmpxchg has not (successfully) executed
+	 * and the operation must be aborted: the pending op pointer needs
+	 * to be cleared. If ZF is set the operation either committed or is
+	 * about to take the failure path with the pending op disarmed, so
+	 * nothing to do.
+	 */
+	return regs->flags & X86_EFLAGS_ZF ? NULL : (void __user *)regs->dx;
+}
+
+#define arch_futex_robust_cmpxchg_get_pending(regs)	\
+	x86_futex_robust_cmpxchg_get_pending(regs)
+
 #endif /* _ASM_X86_FUTEX_ROBUST_H */
