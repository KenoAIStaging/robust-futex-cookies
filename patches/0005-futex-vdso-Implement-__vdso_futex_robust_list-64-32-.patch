+static inline void futex_set_vdso_cmpxchg_cs_range(struct futex_mm_data *fd, unsigned int idx,
+						   unsigned long start, unsigned long abort,
+						   unsigned long end, bool sz32)
+{
+	fd->unlock.cmpxchg_ranges[idx].start_ip = start;
+	fd->unlock.cmpxchg_ranges[idx].abort_ip = abort;
+	fd->unlock.cmpxchg_ranges[idx].len = end - start;
+	fd->unlock.cmpxchg_ranges[idx].pop_size32 = sz32;
+}
