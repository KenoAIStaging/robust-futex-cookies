+
+/*
+ * Assembly template for the RSEQ guarded robust lock functions. The basic
+ * functionality is:
+ *
+ *		mov{q,l}	$0, (pending_ptr)	Disarm the pending op
+ * .Lcs_start:					Start of the critical section
+ *		cmp{q,l}	$0, 8(rseq)	In an RSEQ critical section?
+ *		jz		.Lfail		No: fail
+ *		mov{q,l}	pending, (pending_ptr)	Arm the pending op
+ *		lock cmpxchgl	set, (lock)	Try the expect -> set transition
+ *		jz		.Lsuccess	Acquired: leave pending op armed
+ * .Lcs_abort:					Abort/failure landing pad
+ *		mov{q,l}	$0, (pending_ptr)	Disarm the pending op
+ * .Lcs_end:					End of the critical section
+ * .Lfail:
+ *		return 0
+ * .Lsuccess:
+ *		return 1
+ *
+ * The caller reserves an owner identifier (cookie) for the lock word and
+ * stores TLS::rseq::rseq_cs before invoking this function. Any RSEQ event
+ * (preemption, signal delivery, or an RSEQ IPI from membarrier()) between
+ * the store to rseq_cs and the cmpxchg invalidates the reservation:
+ *
+ *  - An event before .Lcs_start clears rseq_cs, so the check fails.
+ *
+ *  - For an event with the instruction pointer inside
+ *    [.Lcs_start, .Lcs_end) the kernel consults the Zero Flag. ZF == 0
+ *    means the cmpxchg has not (successfully) executed: the kernel clears
+ *    the pending op pointer and moves the instruction pointer to
+ *    .Lcs_abort, which makes the function return 0. The ZF invariant
+ *    holds because a passed rseq_cs check leaves ZF == 0 and MOV does not
+ *    modify flags. ZF == 1 means either the rseq_cs check just failed
+ *    (about to branch to .Lfail with the pending op disarmed) or the
+ *    cmpxchg succeeded and the operation is committed; in both cases no
+ *    fixup is required.
+ *
+ * On success the pending op stays armed with the just written cookie
+ * until the caller has queued the lock in the robust list, mirroring the
+ * list_op_pending protocol of the original robust list.
+ *
+ * The pending op pointer is always in DX, independent of the build mode,
+ * so the kernel side pointer retrieval is uniform. The pointer size is
+ * stored in the matching critical section range struct.
+ *
+ * As with the try_unlock functions there are two entry points to handle
+ * the different robust list pending op pointer sizes.
+ */
+#define CLEAR_PENDQ	"movq	$0, %a[pptr]\n"
+#define CLEAR_PENDL	"movl	$0, %a[pptr]\n"
+#define ARM_PENDQ	"movq	%[pend],  %a[pptr]\n"
+#define ARM_PENDL	"movl	%k[pend], %a[pptr]\n"
+
+/*
+ * struct rseq::rseq_cs is at offset 8. This is statically asserted in
+ * arch/x86/entry/vdso/vma.c. A 32-bit task's rseq_cs value is a 32-bit
+ * pointer stored as u64, so testing the low 32 bits is sufficient in the
+ * 32-bit VDSO.
+ */
+#ifdef __x86_64__
+#define CMP_RSEQ_CS	"cmpq	$0, 8(%[rseq])\n"
+#else
+#define CMP_RSEQ_CS	"cmpl	$0, 8(%[rseq])\n"
+#endif
+
+#define futex_robust_cmpxchg_rseq(prefix, clear_pend, arm_pend,		\
+				  __pptr, __pend, __lock, __val, __set, __rseq) \
+({									\
+	asm volatile (							\
+		"						\n"	\
+			clear_pend					\
+		"						\n"	\
+		LABEL2(prefix, start)					\
+		"						\n"	\
+			CMP_RSEQ_CS					\
+		"	jz	2f				\n"	\
+		"						\n"	\
+			arm_pend					\
+		"						\n"	\
+		"	lock cmpxchgl	%[set], %a[lock]	\n"	\
+		"	jz	1f				\n"	\
+		"						\n"	\
+		LABEL2(prefix, abort)					\
+		"						\n"	\
+			clear_pend					\
+		"						\n"	\
+		LABEL2(prefix, end)					\
+		"2:	xorl	%k[val], %k[val]		\n"	\
+		"	jmp	3f				\n"	\
+		"1:	movl	$1, %k[val]			\n"	\
+		"3:						\n"	\
+		: [val]   "+&a" (__val)					\
+		: [pptr]  "d"   (__pptr),				\
+		  [pend]  "r"   (__pend),				\
+		  [lock]  "r"   (__lock),				\
+		  [set]   "r"   (__set),				\
+		  [rseq]  "r"   (__rseq)				\
+		: "memory", "cc"					\
+	);								\
+	__val;								\
+})
+
+#ifdef __x86_64__
+__u32 __vdso_futex_robust_list64_cmpxchg_rseq(__u64 *pending_ptr, __u64 pending,
+					      __u32 *lock, __u32 expect, __u32 set,
+					      const void *rseq)
+{
+	return futex_robust_cmpxchg_rseq(__futex_list64_cmpxchg_rseq_cs,
+					 CLEAR_PENDQ, ARM_PENDQ,
+					 pending_ptr, pending, lock, expect, set, rseq);
+}
+#endif /* __x86_64__ */
+
+#if defined(CONFIG_X86_32) || defined(CONFIG_COMPAT)
+__u32 __vdso_futex_robust_list32_cmpxchg_rseq(__u32 *pending_ptr, __u32 pending,
+					      __u32 *lock, __u32 expect, __u32 set,
+					      const void *rseq)
+{
+	return futex_robust_cmpxchg_rseq(__futex_list32_cmpxchg_rseq_cs,
+					 CLEAR_PENDL, ARM_PENDL,
+					 pending_ptr, (unsigned long)pending,
+					 lock, expect, set, rseq);
+}
+#endif /* CONFIG_X86_32 || CONFIG_COMPAT */
