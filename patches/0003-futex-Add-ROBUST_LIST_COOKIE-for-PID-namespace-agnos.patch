diff --git a/Documentation/locking/robust-futex-ABI.rst b/Documentation/locking/robust-futex-ABI.rst
index 5e6a0665b8ba..36a564c87a4b 100644
--- a/Documentation/locking/robust-futex-ABI.rst
+++ b/Documentation/locking/robust-futex-ABI.rst
@@ -226,3 +226,89 @@ depending on the size of the pointer). If the vDSO call succeeds, it means that
 it released the lock and cleared ``list_op_pending``. If it fails, that means
 that there are waiters for this lock and a call to ``futex()`` syscall with
 ``FUTEX_ROBUST_UNLOCK`` is needed.
+
+Owner cookies for PID namespace agnostic robust futexes
+=======================================================
+
+The robust list cleanup identifies the locks held by the exiting task by
+comparing the owner part of the futex value (the ``FUTEX_TID_MASK``
+bits) against the exiting task's namespace local TID. TIDs are only
+unique within a PID namespace, so this identification is ambiguous when
+a futex is shared between processes in different PID namespaces: a task
+exiting in one namespace can be wrongly identified as the owner of a
+lock which is held by a live task in another namespace, corrupting the
+lock word and breaking mutual exclusion.
+
+To overcome this, user space can opt into using user space managed
+owner identifiers ("cookies") instead of TIDs by registering the
+extensible list head variant::
+
+    struct robust_list_head2 {
+        struct robust_list_head head;
+        unsigned long flags;
+        long cookie_offset;
+        __u32 list_op_pending_cookie;
+        __u32 __reserved;
+    };
+
+with ``sys_set_robust_list(head, sizeof(struct robust_list_head2))``.
+The 'flags' word is validated and latched at registration time; unknown
+flags are rejected with EINVAL. With ``ROBUST_LIST_COOKIE`` set in
+'flags':
+
+ 1) Each queued lock entry carries a 32 bit cookie at 'cookie_offset'
+    relative to the entry, analogous to 'offset' for the futex word.
+    The exit time cleanup compares the owner part of the futex value
+    against this cookie instead of the TID. The entry cookie must only
+    be written by the lock owner, after acquiring the lock word and
+    before queueing the entry.
+
+ 2) A pending lock operation announced via 'list_op_pending' is
+    attributed via 'list_op_pending_cookie', which the thread sets
+    before storing 'list_op_pending'. The pending operation cannot be
+    attributed through the entry cookie: the entry is embedded in the
+    (shared) lock, and concurrent lock attempts of different tasks
+    would overwrite each other's identifiers while their respective
+    'list_op_pending' is armed.
+
+ 3) The exit time cleanup handles the pending operation *before* the
+    queued entries. A queued entry may implement the lease which keeps
+    the thread's cookie allocated (for instance a registry table slot
+    held via a robust futex); handling the queued entries first would
+    release the cookie for reuse while the stale pending operation
+    still carries it, and a lock legitimately re-acquired under the
+    reused cookie would be marked ``FUTEX_OWNER_DIED`` behind its live
+    owner's back. User space may therefore recycle a cookie as soon as
+    the exit cleanup released its lease, without waiting for the rest
+    of the dead thread's list to be processed. (TID based lists keep
+    the historical entries-then-pending order; a TID cannot be reused
+    before the exiting task is reaped.)
+
+ 4) When the cookie lease is itself a queued robust list entry, user
+    space must order it *after* every lock entry it covers, i.e. the
+    lease entry is enqueued first and later entries are inserted at the
+    head, so the walk reaches the lease last. If the lease were walked
+    while lock entries of the dead thread are still unprocessed, the
+    cookie could be reused and - through a misattributed pending
+    operation of a second dying task - one of those locks could end up
+    re-acquired by a live task before the first walk processes its
+    stale entry, which would then wipe the live owner's lock. Lease
+    types which are released only at process exit (such as OFD file
+    locks, which the kernel drops after all exit time futex cleanup)
+    satisfy this ordering by construction.
+
+User space is responsible for assigning cookies which are unique among
+all tasks which can hold the lock, the same way TIDs are unique among
+all tasks within one PID namespace. The valid cookie domain is
+``1..FUTEX_TID_MASK`` (the owner part of the lock word); an identifier
+with bits outside ``FUTEX_TID_MASK`` never matches and the entry is
+skipped, as are entries carrying the PI modifier bit. The 'flags' and
+'__reserved' fields are validated at registration time. Uniqueness can be organized, for
+instance, with allocation tables in the shared memory itself (with the
+allocations guarded by robust futexes on the table slots), with OFD
+file locks on a shared file, or with per lock reservation counters.
+
+``sys_get_robust_list()`` reports the size which was used at
+registration time. Kernel assisted priority inheritance
+(``FUTEX_LOCK_PI``) is not supported with cookie identifiers, as the
+kernel cannot resolve a cookie to a task.
diff --git a/include/linux/compat.h b/include/linux/compat.h
index 8da0a15c95f4..fdec63231994 100644
--- a/include/linux/compat.h
+++ b/include/linux/compat.h
@@ -399,6 +399,14 @@ struct compat_robust_list_head {
 	compat_uptr_t			list_op_pending;
 };
 
+struct compat_robust_list_head2 {
+	struct compat_robust_list_head	head;
+	compat_ulong_t			flags;
+	compat_long_t			cookie_offset;
+	u32				list_op_pending_cookie;
+	u32				__reserved;
+};
+
 #ifdef CONFIG_COMPAT_OLD_SIGACTION
 struct compat_old_sigaction {
 	compat_uptr_t			sa_handler;
diff --git a/include/linux/futex_types.h b/include/linux/futex_types.h
index d320c0571f0c..d9835ddbafb0 100644
--- a/include/linux/futex_types.h
+++ b/include/linux/futex_types.h
@@ -14,7 +14,11 @@ struct robust_list_head;
 /**
  * struct futex_sched_data - Futex related per task data
  * @robust_list:	User space registered robust list pointer
+ * @robust_list_flags:	ROBUST_LIST_* flags of the registered robust list,
+ *			plus the kernel internal FUTEX_RLIST_V2 marker when
+ *			the registration used struct robust_list_head2
  * @compat_robust_list:	User space registered robust list pointer for compat tasks
+ * @compat_robust_list_flags: Same as @robust_list_flags for the compat list
  * @pi_state_list:	List head for Priority Inheritance (PI) state management
  * @pi_state_cache:	Pointer to cache one PI state object per task
  * @exit_mutex:		Mutex for serializing exit
@@ -22,8 +26,10 @@ struct robust_list_head;
  */
 struct futex_sched_data {
 	struct robust_list_head __user		*robust_list;
+	unsigned int				robust_list_flags;
 #ifdef CONFIG_COMPAT
 	struct compat_robust_list_head __user	*compat_robust_list;
+	unsigned int				compat_robust_list_flags;
 #endif
 	struct list_head			pi_state_list;
 	struct futex_pi_state			*pi_state_cache;
diff --git a/include/uapi/linux/futex.h b/include/uapi/linux/futex.h
index 10a36c551675..b64f024a0996 100644
--- a/include/uapi/linux/futex.h
+++ b/include/uapi/linux/futex.h
@@ -179,6 +179,75 @@ struct robust_list_head {
 	struct robust_list __user *list_op_pending;
 };
 
+/*
+ * Extensible variant of the robust list head above. Registered by handing
+ * sizeof(struct robust_list_head2) as @len to sys_set_robust_list().
+ *
+ * The initial part is layout compatible with the original version, so the
+ * kernel treats it exactly the same way. The extension adds a flags field
+ * to enable optional functionality and further extensions.
+ */
+struct robust_list_head2 {
+	struct robust_list_head head;
+
+	/*
+	 * ROBUST_LIST_* flags. Validated when the list head is registered.
+	 * Registration fails with -EINVAL if unknown flags are set.
+	 */
+	unsigned long flags;
+
+	/*
+	 * Only valid when ROBUST_LIST_COOKIE is set in @flags:
+	 *
+	 * Each queued list entry carries a 32-bit cookie at this relative
+	 * offset from the entry, analogous to
+	 * robust_list_head::futex_offset.
+	 *
+	 * The cleanup code at task exit compares the owner part
+	 * (FUTEX_TID_MASK) of the futex value against the entry's cookie
+	 * instead of the exiting task's TID. This allows the use of robust
+	 * futexes shared between processes in different PID namespaces,
+	 * where TIDs are ambiguous, by using user space managed unique
+	 * cookies as owner identifiers.
+	 *
+	 * The valid cookie domain is 1..FUTEX_TID_MASK, matching the
+	 * owner part of the futex value. A cookie with bits outside
+	 * FUTEX_TID_MASK set never matches any futex value: the entry is
+	 * skipped by the exit cleanup (fail closed) instead of aliasing a
+	 * valid identifier. A cookie of 0 means "unlocked" and never
+	 * matches an owned futex either.
+	 *
+	 * The entry cookie is only ever written by the lock owner, after
+	 * the lock word has been acquired and before the entry is queued
+	 * in the list. Entries carrying FUTEX_ROBUST_MOD_PI are invalid
+	 * on a cookie list (the kernel cannot resolve a cookie to a task
+	 * for PI ownership) and are skipped by the exit cleanup.
+	 */
+	long cookie_offset;
+
+	/*
+	 * Only valid when ROBUST_LIST_COOKIE is set in @flags:
+	 *
+	 * The cookie for the entry pointed to by
+	 * robust_list_head::list_op_pending.
+	 *
+	 * An in flight lock operation cannot use the entry cookie: the
+	 * entry is embedded in the (potentially shared) lock and racing
+	 * lock attempts of other tasks would overwrite each other's
+	 * cookies while their respective list_op_pending is armed, which
+	 * would allow the exit cleanup to misattribute a lock to a dying
+	 * task. This field belongs to the registering task alone and is
+	 * set before list_op_pending is armed.
+	 */
+	__u32 list_op_pending_cookie;
+
+	/* Must be 0, registration fails with -EINVAL otherwise */
+	__u32 __reserved;
+};
+
+/* Valid bits for robust_list_head2::flags */
+#define ROBUST_LIST_COOKIE		(0x1UL)
+
 /*
  * Are there any waiters for this robust futex:
  */
diff --git a/kernel/futex/core.c b/kernel/futex/core.c
index e1a8772e4d48..1f431cc9fee6 100644
--- a/kernel/futex/core.c
+++ b/kernel/futex/core.c
@@ -964,13 +964,21 @@ void futex_unqueue_pi(struct futex_q *q)
 /*
  * Process a futex-list entry, check whether it's owned by the
  * dying task, and do notification if so:
+ *
+ * @owner_id is the value against which the owner part (FUTEX_TID_MASK) of
+ * the futex value is compared: the TID of the exiting task or, on a
+ * ROBUST_LIST_COOKIE enabled list, the user space provided cookie of the
+ * entry (resp. robust_list_head2::list_op_pending_cookie for the pending
+ * op). The valid identifier domain is 1..FUTEX_TID_MASK; @owner_id is
+ * deliberately not masked, so an out of domain identifier never matches
+ * any futex value and the entry is skipped (fail closed) instead of
+ * aliasing a valid owner.
  */
 static int handle_futex_death(u32 __user *uaddr, struct task_struct *curr,
-			      unsigned int mod, bool pending_op)
+			      unsigned int mod, bool pending_op, u32 owner_id)
 {
 	bool pi = !!(mod & FUTEX_ROBUST_MOD_PI);
-	u32 uval, nval, mval;
-	pid_t owner;
+	u32 uval, nval, mval, owner;
 	int err;
 
 	/* Futex address must be 32bit aligned */
@@ -1025,7 +1033,7 @@ static int handle_futex_death(u32 __user *uaddr, struct task_struct *curr,
 		return 0;
 	}
 
-	if (owner != task_pid_vnr(curr)) {
+	if (owner != owner_id) {
 		/*
 		 * The dying task's pending op may have consumed the wake up
 		 * notification of a robust unlock: woken, then killed before
@@ -1121,6 +1129,28 @@ static inline int fetch_robust_entry(struct robust_list __user **entry,
 	return 0;
 }
 
+/*
+ * Fetch the owner identifier for a queued robust list entry: the user
+ * space managed cookie stored relative to the entry on a
+ * ROBUST_LIST_COOKIE enabled list, otherwise the TID of the exiting
+ * task.
+ *
+ * The pending entry (robust_list_head::list_op_pending) is attributed
+ * via robust_list_head2::list_op_pending_cookie instead: the entry
+ * cookie is owned by whoever holds the lock, while the pending op
+ * belongs to a lock operation which is still in flight.
+ */
+static inline int fetch_robust_owner_id(struct robust_list __user *entry,
+					bool cookies, long cookie_offset,
+					u32 tid, u32 *owner_id)
+{
+	if (likely(!cookies)) {
+		*owner_id = tid;
+		return 0;
+	}
+	return get_user(*owner_id, (u32 __user *)((void __user *)entry + cookie_offset));
+}
+
 /*
  * Walk curr->futex.robust_list (very carefully, it's a userspace list!)
  * and mark any locks found there dead, and notify any waiters.
@@ -1132,9 +1162,30 @@ static void exit_robust_list(struct task_struct *curr)
 	struct robust_list_head __user *head = curr->futex.robust_list;
 	unsigned int limit = ROBUST_LIST_LIMIT, cur_mod, next_mod, pend_mod;
 	struct robust_list __user *entry, *next_entry, *pending;
+	bool cookies = curr->futex.robust_list_flags & ROBUST_LIST_COOKIE;
+	struct robust_list __user *pending_next = NULL;
+	unsigned int pending_next_mod = 0;
+	bool pending_handled = false;
+	int pending_next_rc = 0;
+	long cookie_offset = 0;
 	unsigned long futex_offset;
+	u32 tid = task_pid_vnr(curr), owner_id, pending_cookie = tid;
 	int rc;
 
+	/*
+	 * If the list head was registered with ROBUST_LIST_COOKIE, fetch
+	 * the relative cookie offset and the cookie for a potentially
+	 * pending lock operation:
+	 */
+	if (cookies) {
+		struct robust_list_head2 __user *head2 = (void __user *)head;
+
+		if (get_user(cookie_offset, &head2->cookie_offset))
+			return;
+		if (get_user(pending_cookie, &head2->list_op_pending_cookie))
+			return;
+	}
+
 	/*
 	 * Fetch the list head (which was registered earlier, via
 	 * sys_set_robust_list()):
@@ -1153,20 +1204,70 @@ static void exit_robust_list(struct task_struct *curr)
 	if (fetch_robust_entry(&pending, &head->list_op_pending, &pend_mod))
 		return;
 
+	/*
+	 * On a ROBUST_LIST_COOKIE list the pending op must be handled
+	 * before any queued entry: a queued entry can implement the
+	 * lease which keeps the pending cookie allocated to this task
+	 * (e.g. a registry slot held via a robust futex). Handling the
+	 * queued entries first would release that lease while the stale
+	 * pending op still carries the cookie; a new task could then
+	 * legitimately reuse the cookie and acquire the pending op's
+	 * lock, and the late pending handling would mark the live
+	 * owner's lock OWNER_DIED.
+	 *
+	 * The pending entry might already be linked into the list, and
+	 * once the pending op was handled a new owner can acquire the
+	 * lock and requeue the entry on its own list, overwriting its
+	 * ->next link. Therefore fetch the successor before handling
+	 * the pending op; the list walk below uses the prefetched
+	 * successor when it reaches the entry.
+	 *
+	 * TID based lists keep the historical order: TIDs cannot be
+	 * reused before the exiting task is reaped, so the walk order
+	 * does not matter there.
+	 */
+	if (cookies && pending) {
+		pending_next_rc = fetch_robust_entry(&pending_next,
+						     &pending->next,
+						     &pending_next_mod);
+		if (!(pend_mod & FUTEX_ROBUST_MOD_PI))
+			handle_futex_death((void __user *)pending + futex_offset,
+					   curr, pend_mod, HANDLE_DEATH_PENDING,
+					   pending_cookie);
+		pending_handled = true;
+	}
+
 	next_entry = NULL;	/* avoid warning with gcc */
 	while (entry != &head->list) {
 		/*
 		 * Fetch the next entry in the list before calling
-		 * handle_futex_death:
+		 * handle_futex_death. If this entry is the already
+		 * handled pending op, its ->next may have been
+		 * overwritten by a new owner meanwhile: use the
+		 * successor fetched above instead.
 		 */
-		rc = fetch_robust_entry(&next_entry, &entry->next, &next_mod);
+		if (pending_handled && entry == pending) {
+			rc = pending_next_rc;
+			next_entry = pending_next;
+			next_mod = pending_next_mod;
+		} else {
+			rc = fetch_robust_entry(&next_entry, &entry->next, &next_mod);
+		}
 		/*
 		 * A pending lock might already be on the list, so
-		 * don't process it twice:
+		 * don't process it twice. Kernel side PI ownership
+		 * cannot work with cookie identifiers (the kernel
+		 * cannot resolve a cookie to a task), so PI marked
+		 * entries on a cookie list are skipped (fail closed):
 		 */
-		if (entry != pending) {
+		if (entry != pending &&
+		    !(cookies && (cur_mod & FUTEX_ROBUST_MOD_PI))) {
+			if (fetch_robust_owner_id(entry, cookies, cookie_offset,
+						  tid, &owner_id))
+				return;
 			if (handle_futex_death((void __user *)entry + futex_offset,
-						curr, cur_mod, HANDLE_DEATH_LIST))
+						curr, cur_mod, HANDLE_DEATH_LIST,
+						owner_id))
 				return;
 		}
 		if (rc)
@@ -1182,9 +1283,10 @@ static void exit_robust_list(struct task_struct *curr)
 		cond_resched();
 	}
 
-	if (pending) {
+	if (pending && !pending_handled) {
 		handle_futex_death((void __user *)pending + futex_offset,
-				   curr, pend_mod, HANDLE_DEATH_PENDING);
+				   curr, pend_mod, HANDLE_DEATH_PENDING,
+				   pending_cookie);
 	}
 }
 
@@ -1219,6 +1321,23 @@ static void __user *futex_uaddr(struct robust_list __user *entry,
 	return uaddr;
 }
 
+/*
+ * Compat variant of fetch_robust_owner_id(): the cookie address must be
+ * computed with 32-bit wrapping semantics, exactly like futex_uaddr()
+ * computes the futex word address.
+ */
+static inline int compat_fetch_robust_owner_id(struct robust_list __user *entry,
+					       bool cookies,
+					       compat_long_t cookie_offset,
+					       u32 tid, u32 *owner_id)
+{
+	if (likely(!cookies)) {
+		*owner_id = tid;
+		return 0;
+	}
+	return get_user(*owner_id, (u32 __user *)futex_uaddr(entry, cookie_offset));
+}
+
 /*
  * Fetch a robust-list pointer. Bit 0 signals PI futexes:
  */
@@ -1246,10 +1365,27 @@ static void compat_exit_robust_list(struct task_struct *curr)
 	struct compat_robust_list_head __user *head = current->futex.compat_robust_list;
 	unsigned int limit = ROBUST_LIST_LIMIT, cur_mod, next_mod, pend_mod;
 	struct robust_list __user *entry, *next_entry, *pending;
+	bool cookies = curr->futex.compat_robust_list_flags & ROBUST_LIST_COOKIE;
 	compat_uptr_t uentry, next_uentry, upending;
-	compat_long_t futex_offset;
+	struct robust_list __user *pending_next = NULL;
+	compat_uptr_t pending_next_uentry = 0;
+	unsigned int pending_next_mod = 0;
+	bool pending_handled = false;
+	int pending_next_rc = 0;
+	compat_long_t futex_offset, cookie_offset = 0;
+	u32 tid = task_pid_vnr(curr), owner_id, pending_cookie = tid;
 	int rc;
 
+	/* See exit_robust_list() */
+	if (cookies) {
+		struct compat_robust_list_head2 __user *head2 = (void __user *)head;
+
+		if (get_user(cookie_offset, &head2->cookie_offset))
+			return;
+		if (get_user(pending_cookie, &head2->list_op_pending_cookie))
+			return;
+	}
