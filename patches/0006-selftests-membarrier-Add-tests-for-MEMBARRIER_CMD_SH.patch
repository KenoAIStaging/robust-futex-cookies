--- /dev/null
+++ b/tools/testing/selftests/membarrier/membarrier_shared_rseq_test.c
@@ -0,0 +1,432 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Tests for MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ: an RSEQ fence targeting
+ * all processes which have a shared writable mapping of a given page and
+ * have registered with MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ.
+ */
+#define _GNU_SOURCE
+#ifndef __x86_64__
+#error "This test contains x86-64 specific RSEQ assembly (see the Makefile gate)"
+#endif
+
+#include <errno.h>
+#include <linux/futex.h>
+#include <linux/membarrier.h>
+#include <sched.h>
+#include <signal.h>
+#include <stdatomic.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <string.h>
+#include <sys/mman.h>
+#include <sys/syscall.h>
+#include <sys/time.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#include "../kselftest_harness.h"
+
+#ifndef MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ
+#define MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ		(1 << 10)
+#define MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ	(1 << 11)
+#endif
+
+#define RSEQ_SIG	0x53053053
+
+static int sys_membarrier(int cmd, unsigned int flags, int cpu_id, unsigned long addr)
+{
+	return syscall(__NR_membarrier, cmd, flags, cpu_id, addr);
+}
+
+static __thread struct rseq_abi {
+	uint32_t cpu_id_start;
+	uint32_t cpu_id;
+	uint64_t rseq_cs;
+	uint32_t flags;
+} __attribute__((aligned(32))) own_rseq;
+
+static int register_rseq(void)
+{
+	return syscall(SYS_rseq, &own_rseq, sizeof(own_rseq), 0, RSEQ_SIG);
+}
+
+/*
+ * Run @fn(@arg) on a "libc-less" thread: a raw clone(CLONE_VM|CLONE_THREAD)
+ * task the C library never set up, so the kernel starts it with rseq ==
+ * NULL. It can therefore register its own rseq regardless of the libc
+ * version (modern glibc auto-registers rseq on every thread it creates,
+ * which would make register_rseq() above fail with EINVAL). The thread
+ * shares the caller's address space (and thus its per-mm membarrier
+ * registration state, as the tests require) and is joined via a
+ * CLONE_CHILD_CLEARTID futex. Returns @fn's value or a negative errno.
+ */
+struct bare_ctx {
+	int (*fn)(void *);
+	void *arg;
+	int ret;
+};
+
+static int bare_entry(void *p)
+{
+	struct bare_ctx *c = p;
+
+	c->ret = c->fn(c->arg);
+	return 0;
+}
+
+static int run_libcless(int (*fn)(void *), void *arg)
+{
+	const size_t sz = 256 * 1024;
+	struct bare_ctx ctx = { fn, arg, 0 };
+	volatile pid_t ctid = 1;
+	char *stack;
+	long tid;
+
+	stack = mmap(NULL, sz, PROT_READ | PROT_WRITE,
+		     MAP_PRIVATE | MAP_ANONYMOUS | MAP_STACK, -1, 0);
+	if (stack == MAP_FAILED)
+		return -errno;
+
+	tid = clone(bare_entry, stack + sz,
+		    CLONE_VM | CLONE_FS | CLONE_FILES | CLONE_SIGHAND |
+		    CLONE_THREAD | CLONE_CHILD_CLEARTID,
+		    &ctx, NULL, NULL, (pid_t *)&ctid);
+	if (tid < 0) {
+		int e = errno;
+
+		munmap(stack, sz);
+		return -e;
+	}
+
+	for (;;) {
+		pid_t v = __atomic_load_n(&ctid, __ATOMIC_ACQUIRE);
+
+		if (!v)
+			break;
+		syscall(SYS_futex, &ctid, FUTEX_WAIT, v, NULL, NULL, 0);
+	}
+	munmap(stack, sz);
+	return ctx.ret;
+}
+
+/*
+ * Shared state between the fencing parent and the spinning children.
+ */
+struct shared_state {
+	_Atomic(int)	stop;
+	_Atomic(int)	in_cs;
+	_Atomic(int)	aborts;
+};
+
+/*
+ * Spin inside an RSEQ critical section until either *stop is set (normal,
+ * committed exit; returns false) or the critical section is aborted by an
+ * RSEQ event (returns true).
+ */
+static bool __attribute__((noinline)) rseq_spin(struct shared_state *sh)
+{
+	asm volatile goto (
+		".pushsection __rseq_cs_section, \"aw\"\n\t"
+		".balign 32\n\t"
+		"3:\n\t"
+		".long 0, 0\n\t"
+		".quad 1f, (2f - 1f), 4f\n\t"
+		".popsection\n\t"
+		"leaq 3b(%%rip), %%rax\n\t"
+		"movq %%rax, %[rseq_cs]\n\t"
+		"1:\n\t"
+		"movl $1, %[in_cs]\n\t"
+		"5:\n\t"
+		"cmpl $0, %[stop]\n\t"
+		"jne 2f\n\t"
+		"pause\n\t"
+		"jmp 5b\n\t"
+		"2:\n\t"
+		"jmp 6f\n\t"
+		".long 0x53053053\n\t"	/* RSEQ_SIG */
+		"4:\n\t"
+		"jmp %l[cs_abort]\n\t"
+		"6:\n\t"
+		:
+		: [rseq_cs] "m" (own_rseq.rseq_cs),
+		  [in_cs]   "m" (sh->in_cs),
+		  [stop]    "m" (sh->stop)
+		: "rax", "memory"
+		: cs_abort);
+	return false;
+cs_abort:
+	return true;
+}
+
+struct spinner_ctx {
+	struct shared_state *sh;
+	bool register_membarrier;
+};
+
+static int spinner_body(void *p)
+{
+	struct spinner_ctx *c = p;
+	struct shared_state *sh = c->sh;
+
+	if (register_rseq())
+		return 1;
+	if (c->register_membarrier &&
+	    sys_membarrier(MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ, 0, 0, 0))
+		return 2;
+
+	while (!atomic_load(&sh->stop)) {
+		if (rseq_spin(sh))
+			atomic_fetch_add(&sh->aborts, 1);
+	}
+	return 0;
+}
+
+static pid_t spawn_spinner(struct shared_state *sh, bool register_membarrier)
+{
+	struct spinner_ctx ctx = { sh, register_membarrier };
+	pid_t pid = fork();
+
+	if (pid)
+		return pid;
+
+	/*
+	 * The forked child inherited the libc's rseq registration; run the
+	 * spinner on a libc-less thread so it owns rseq regardless of the
+	 * libc version. The thread shares this child's mm, so the per-mm
+	 * membarrier registration state the tests set up is preserved.
+	 */
+	_exit(run_libcless(spinner_body, &ctx));
+}
+
+static void stop_spinner(struct shared_state *sh, pid_t pid, int *wstatus)
+{
+	atomic_store(&sh->stop, 1);
+	waitpid(pid, wstatus, 0);
+}
+
+FIXTURE(shared_rseq)
+{
+	struct shared_state *sh;
+};
+
+FIXTURE_SETUP(shared_rseq)
+{
+	int ret;
+
+	ret = sys_membarrier(MEMBARRIER_CMD_QUERY, 0, 0, 0);
+	if (ret < 0 || !(ret & MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ))
+		SKIP(return, "MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ not supported");
+
+	self->sh = mmap(NULL, getpagesize(), PROT_READ | PROT_WRITE,
+			MAP_SHARED | MAP_ANONYMOUS, -1, 0);
+	ASSERT_NE(self->sh, MAP_FAILED);
+	memset(self->sh, 0, sizeof(*self->sh));
+}
+
+FIXTURE_TEARDOWN(shared_rseq)
+{
+	munmap(self->sh, getpagesize());
+}
+
+/*
+ * Argument validation: unregistered caller, non shared mappings and read
+ * only mappings are rejected.
+ */
+TEST_F(shared_rseq, errors)
+{
+	void *priv, *ro;
+	int ret;
+
+	/* Not registered yet: EPERM */
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 0, 0,
+			     (unsigned long)self->sh);
+	ASSERT_EQ(ret, -1);
+	ASSERT_EQ(errno, EPERM);
+
+	ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ,
+				 0, 0, 0), 0);
+
+	/* Private mapping: EINVAL */
+	priv = mmap(NULL, getpagesize(), PROT_READ | PROT_WRITE,
+		    MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+	ASSERT_NE(priv, MAP_FAILED);
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 0, 0,
+			     (unsigned long)priv);
+	ASSERT_EQ(ret, -1);
+	ASSERT_EQ(errno, EINVAL);
+	munmap(priv, getpagesize());
+
+	/* Read only shared mapping: EINVAL */
+	ro = mmap(NULL, getpagesize(), PROT_READ,
+		  MAP_SHARED | MAP_ANONYMOUS, -1, 0);
+	ASSERT_NE(ro, MAP_FAILED);
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 0, 0,
+			     (unsigned long)ro);
+	ASSERT_EQ(ret, -1);
+	ASSERT_EQ(errno, EINVAL);
+	munmap(ro, getpagesize());
+
+	/* Unmapped address: EINVAL */
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 0, 0, 0);
+	ASSERT_EQ(ret, -1);
+	ASSERT_EQ(errno, EINVAL);
+
+	/* Non zero flags: EINVAL */
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 1, 0,
+			     (unsigned long)self->sh);
+	ASSERT_EQ(ret, -1);
+	ASSERT_EQ(errno, EINVAL);
+
+	/* Valid call with no targets */
+	ret = sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, 0, 0,
+			     (unsigned long)self->sh);
+	ASSERT_EQ(ret, 0);
+}
+
+/*
+ * The fence aborts the RSEQ critical section of a registered process
+ * which shares a writable mapping of the page.
+ */
+TEST_F(shared_rseq, fence_aborts_target)
+{
+	struct shared_state *sh = self->sh;
+	int wstatus, tries, fences;
+	pid_t pid;
+
+	ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ,
+				 0, 0, 0), 0);
+
+	pid = spawn_spinner(sh, true);
+	ASSERT_GT(pid, 0);
+
+	/* Wait for the child to spin inside the critical section */
+	for (tries = 0; !atomic_load(&sh->in_cs) && tries < 5000; tries++)
+		usleep(1000);
+	ASSERT_TRUE(atomic_load(&sh->in_cs));
+
+	/*
+	 * Discard aborts which happened before the first fence (startup
+	 * preemptions/migrations also abort the critical section): the
+	 * test must never pass without issuing at least one fence, and
+	 * only aborts observed after a fence count.
+	 */
+	atomic_store(&sh->aborts, 0);
+
+	/*
+	 * The child spends a few instructions per abort outside of the
+	 * critical section, so a fence can miss. Retry a couple of times.
+	 */
+	for (tries = 0, fences = 0; tries < 100; tries++) {
+		ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ,
+					 0, 0, (unsigned long)sh), 0);
+		fences++;
+		usleep(10000);
+		if (atomic_load(&sh->aborts))
+			break;
+	}
+
+	stop_spinner(sh, pid, &wstatus);
+	ASSERT_EQ(WEXITSTATUS(wstatus), 0);
+	ASSERT_GT(fences, 0);
+	ASSERT_GT(atomic_load(&sh->aborts), 0);
+}
+
+/*
+ * The spinner's critical section is aborted by every RSEQ event, so
+ * unrelated preemptions and migrations are counted as well. To decide
+ * whether the fences disturb the spinner, compare the abort count of a
+ * fence-free control phase against a phase with a fence per iteration.
+ * A wrongly targeted spinner accrues (nearly) one abort per fence, far
+ * above the background noise.
+ */
+static void fence_noise_compare(struct __test_metadata *_metadata,
+				struct shared_state *sh, unsigned long fence_addr)
+{
+	int control = 0, fenced = 0, i;
+
+	for (i = 0; i < 20; i++) {
+		usleep(5000);
+		control += atomic_exchange(&sh->aborts, 0);
+	}
+
+	for (i = 0; i < 20; i++) {
+		ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ,
+					 0, 0, fence_addr), 0);
+		usleep(5000);
+		fenced += atomic_exchange(&sh->aborts, 0);
+	}
+
+	ksft_print_msg("aborts: %d control vs %d with 20 fences\n", control, fenced);
+	ASSERT_LE(fenced, control + 5);
+}
+
+/*
+ * A process which did not register must not be disturbed, even though it
+ * shares a writable mapping of the page.
+ */
+TEST_F(shared_rseq, fence_skips_unregistered)
+{
+	struct shared_state *sh = self->sh;
+	int wstatus, i;
+	pid_t pid;
+
+	/*
+	 * The membarrier registration is a property of the mm and thus
+	 * inherited by fork(). Spawn the unregistered child before the
+	 * parent registers itself.
+	 */
+	pid = spawn_spinner(sh, false);
+	ASSERT_GT(pid, 0);
+
+	ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ,
+				 0, 0, 0), 0);
+
+	for (i = 0; !atomic_load(&sh->in_cs) && i < 5000; i++)
+		usleep(1000);
+	ASSERT_TRUE(atomic_load(&sh->in_cs));
+
+	fence_noise_compare(_metadata, sh, (unsigned long)sh);
+
+	stop_spinner(sh, pid, &wstatus);
+	ASSERT_EQ(WEXITSTATUS(wstatus), 0);
+}
+
+/*
+ * A registered process which does not map the fenced page must not be
+ * disturbed.
+ */
+TEST_F(shared_rseq, fence_skips_non_mapping)
+{
+	struct shared_state *sh = self->sh;
+	struct shared_state *other;
+	int wstatus, i;
+	pid_t pid;
+
+	ASSERT_EQ(sys_membarrier(MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ,
+				 0, 0, 0), 0);
+
+	/* The child spins on @sh and is registered via fork inheritance */
+	pid = spawn_spinner(sh, true);
+	ASSERT_GT(pid, 0);
+
+	/*
+	 * Map the fence target page after the fork, so the child has no
+	 * mapping of it.
+	 */
+	other = mmap(NULL, getpagesize(), PROT_READ | PROT_WRITE,
+		     MAP_SHARED | MAP_ANONYMOUS, -1, 0);
+	ASSERT_NE(other, MAP_FAILED);
+	memset(other, 0, sizeof(*other));
+
+	for (i = 0; !atomic_load(&sh->in_cs) && i < 5000; i++)
+		usleep(1000);
+	ASSERT_TRUE(atomic_load(&sh->in_cs));
+
+	fence_noise_compare(_metadata, sh, (unsigned long)other);
+
+	stop_spinner(sh, pid, &wstatus);
+	ASSERT_EQ(WEXITSTATUS(wstatus), 0);
+	munmap(other, getpagesize());
+}
+
+TEST_HARNESS_MAIN
-- 
