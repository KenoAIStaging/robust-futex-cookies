index 8da0a15c95f4..fdec63231994 100644
--- a/include/linux/compat.h
+++ b/include/linux/compat.h
@@ -399,6 +399,14 @@ struct compat_robust_list_head {
 	compat_uptr_t			list_op_pending;
 };
 
+struct compat_robust_list_head2 {
+	struct compat_robust_list_head	head;
+	compat_ulong_t			flags;
+	compat_long_t			cookie_offset;
+	u32				list_op_pending_cookie;
+	u32				__reserved;
+};
+
 #ifdef CONFIG_COMPAT_OLD_SIGACTION
 struct compat_old_sigaction {
 	compat_uptr_t			sa_handler;
diff --git a/include/linux/futex_types.h b/include/linux/futex_types.h
index d320c0571f0c..d9835ddbafb0 100644
--- a/include/linux/futex_types.h
+++ b/include/linux/futex_types.h
@@ -14,7 +14,11 @@ struct robust_list_head;
 /**
  * struct futex_sched_data - Futex related per task data
  * @robust_list:	User space registered robust list pointer
+ * @robust_list_flags:	ROBUST_LIST_* flags of the registered robust list,
+ *			plus the kernel internal FUTEX_RLIST_V2 marker when
+ *			the registration used struct robust_list_head2
  * @compat_robust_list:	User space registered robust list pointer for compat tasks
+ * @compat_robust_list_flags: Same as @robust_list_flags for the compat list
  * @pi_state_list:	List head for Priority Inheritance (PI) state management
  * @pi_state_cache:	Pointer to cache one PI state object per task
  * @exit_mutex:		Mutex for serializing exit
@@ -22,8 +26,10 @@ struct robust_list_head;
  */
 struct futex_sched_data {
 	struct robust_list_head __user		*robust_list;
+	unsigned int				robust_list_flags;
 #ifdef CONFIG_COMPAT
 	struct compat_robust_list_head __user	*compat_robust_list;
+	unsigned int				compat_robust_list_flags;
 #endif
 	struct list_head			pi_state_list;
 	struct futex_pi_state			*pi_state_cache;
diff --git a/include/uapi/linux/futex.h b/include/uapi/linux/futex.h
index 10a36c551675..8eb64cc91819 100644
--- a/include/uapi/linux/futex.h
+++ b/include/uapi/linux/futex.h
@@ -179,6 +179,64 @@ struct robust_list_head {
 	struct robust_list __user *list_op_pending;
 };
 
+/*
+ * Extensible variant of the robust list head above. Registered by handing
+ * sizeof(struct robust_list_head2) as @len to sys_set_robust_list().
+ *
+ * The initial part is layout compatible with the original version, so the
+ * kernel treats it exactly the same way. The extension adds a flags field
+ * to enable optional functionality and further extensions.
+ */
+struct robust_list_head2 {
+	struct robust_list_head head;
+
+	/*
+	 * ROBUST_LIST_* flags. Validated when the list head is registered.
+	 * Registration fails with -EINVAL if unknown flags are set.
+	 */
+	unsigned long flags;
+
+	/*
+	 * Only valid when ROBUST_LIST_COOKIE is set in @flags:
+	 *
+	 * Each queued list entry carries a 32-bit cookie at this relative
+	 * offset from the entry, analogous to
+	 * robust_list_head::futex_offset.
+	 *
+	 * The cleanup code at task exit compares the owner part
+	 * (FUTEX_TID_MASK) of the futex value against the entry's cookie
+	 * instead of the exiting task's TID. This allows the use of robust
+	 * futexes shared between processes in different PID namespaces,
+	 * where TIDs are ambiguous, by using user space managed unique
+	 * cookies as owner identifiers.
+	 *
+	 * The entry cookie is only ever written by the lock owner, after
+	 * the lock word has been acquired and before the entry is queued
+	 * in the list.
+	 */
+	long cookie_offset;
+
+	/*
+	 * Only valid when ROBUST_LIST_COOKIE is set in @flags:
+	 *
+	 * The cookie for the entry pointed to by
+	 * robust_list_head::list_op_pending.
+	 *
+	 * An in flight lock operation cannot use the entry cookie: the
+	 * entry is embedded in the (potentially shared) lock and racing
+	 * lock attempts of other tasks would overwrite each other's
+	 * cookies while their respective list_op_pending is armed, which
+	 * would allow the exit cleanup to misattribute a lock to a dying
+	 * task. This field belongs to the registering task alone and is
+	 * set before list_op_pending is armed.
+	 */
+	__u32 list_op_pending_cookie;
+	__u32 __reserved;
+};
+
+/* Valid bits for robust_list_head2::flags */
+#define ROBUST_LIST_COOKIE		(0x1UL)
+
 /*
  * Are there any waiters for this robust futex:
  */
diff --git a/kernel/futex/core.c b/kernel/futex/core.c
index 179b26e9c934..bd50e5969131 100644
--- a/kernel/futex/core.c
+++ b/kernel/futex/core.c
@@ -964,13 +964,17 @@ void futex_unqueue_pi(struct futex_q *q)
 /*
  * Process a futex-list entry, check whether it's owned by the
  * dying task, and do notification if so:
+ *
+ * @owner_id is the value against which the owner part (FUTEX_TID_MASK) of
+ * the futex value is compared: the TID of the exiting task or, for entries
+ * with FUTEX_ROBUST_MOD_COOKIE set on a ROBUST_LIST_COOKIE enabled list,
+ * the user space provided cookie of the entry.
  */
 static int handle_futex_death(u32 __user *uaddr, struct task_struct *curr,
-			      unsigned int mod, bool pending_op)
+			      unsigned int mod, bool pending_op, u32 owner_id)
 {
 	bool pi = !!(mod & FUTEX_ROBUST_MOD_PI);
-	u32 uval, nval, mval;
-	pid_t owner;
+	u32 uval, nval, mval, owner;
 	int err;
 
 	/* Futex address must be 32bit aligned */
@@ -1025,7 +1029,7 @@ static int handle_futex_death(u32 __user *uaddr, struct task_struct *curr,
 		return 0;
 	}
 
-	if (owner != task_pid_vnr(curr))
+	if (owner != (owner_id & FUTEX_TID_MASK))
 		return 0;
 
 	/*
@@ -1099,6 +1103,28 @@ static inline int fetch_robust_entry(struct robust_list __user **entry,
 	return 0;
 }
 
+/*
+ * Fetch the owner identifier for a queued robust list entry: the user
+ * space managed cookie stored relative to the entry on a
+ * ROBUST_LIST_COOKIE enabled list, otherwise the TID of the exiting
+ * task.
+ *
+ * The pending entry (robust_list_head::list_op_pending) is attributed
+ * via robust_list_head2::list_op_pending_cookie instead: the entry
+ * cookie is owned by whoever holds the lock, while the pending op
+ * belongs to a lock operation which is still in flight.
+ */
+static inline int fetch_robust_owner_id(struct robust_list __user *entry,
+					bool cookies, long cookie_offset,
+					u32 tid, u32 *owner_id)
+{
+	if (likely(!cookies)) {
+		*owner_id = tid;
+		return 0;
+	}
+	return get_user(*owner_id, (u32 __user *)((void __user *)entry + cookie_offset));
+}
+
 /*
  * Walk curr->futex.robust_list (very carefully, it's a userspace list!)
  * and mark any locks found there dead, and notify any waiters.
@@ -1110,9 +1136,26 @@ static void exit_robust_list(struct task_struct *curr)
 	struct robust_list_head __user *head = curr->futex.robust_list;
 	unsigned int limit = ROBUST_LIST_LIMIT, cur_mod, next_mod, pend_mod;
 	struct robust_list __user *entry, *next_entry, *pending;
+	bool cookies = curr->futex.robust_list_flags & ROBUST_LIST_COOKIE;
+	long cookie_offset = 0;
 	unsigned long futex_offset;
+	u32 tid = task_pid_vnr(curr), owner_id, pending_cookie = tid;
 	int rc;
 
+	/*
+	 * If the list head was registered with ROBUST_LIST_COOKIE, fetch
+	 * the relative cookie offset and the cookie for a potentially
+	 * pending lock operation:
+	 */
+	if (cookies) {
+		struct robust_list_head2 __user *head2 = (void __user *)head;
+
+		if (get_user(cookie_offset, &head2->cookie_offset))
+			return;
+		if (get_user(pending_cookie, &head2->list_op_pending_cookie))
+			return;
+	}
+
 	/*
 	 * Fetch the list head (which was registered earlier, via
 	 * sys_set_robust_list()):
@@ -1143,8 +1186,12 @@ static void exit_robust_list(struct task_struct *curr)
 		 * don't process it twice:
 		 */
 		if (entry != pending) {
+			if (fetch_robust_owner_id(entry, cookies, cookie_offset,
+						  tid, &owner_id))
+				return;
 			if (handle_futex_death((void __user *)entry + futex_offset,
-						curr, cur_mod, HANDLE_DEATH_LIST))
+						curr, cur_mod, HANDLE_DEATH_LIST,
+						owner_id))
 				return;
 		}
 		if (rc)
@@ -1162,7 +1209,8 @@ static void exit_robust_list(struct task_struct *curr)
 
 	if (pending) {
 		handle_futex_death((void __user *)pending + futex_offset,
-				   curr, pend_mod, HANDLE_DEATH_PENDING);
+				   curr, pend_mod, HANDLE_DEATH_PENDING,
+				   pending_cookie);
 	}
 }
 
@@ -1224,10 +1272,22 @@ static void compat_exit_robust_list(struct task_struct *curr)
 	struct compat_robust_list_head __user *head = current->futex.compat_robust_list;
 	unsigned int limit = ROBUST_LIST_LIMIT, cur_mod, next_mod, pend_mod;
 	struct robust_list __user *entry, *next_entry, *pending;
+	bool cookies = curr->futex.compat_robust_list_flags & ROBUST_LIST_COOKIE;
 	compat_uptr_t uentry, next_uentry, upending;
-	compat_long_t futex_offset;
+	compat_long_t futex_offset, cookie_offset = 0;
+	u32 tid = task_pid_vnr(curr), owner_id, pending_cookie = tid;
 	int rc;
 
+	/* See exit_robust_list() */
+	if (cookies) {
+		struct compat_robust_list_head2 __user *head2 = (void __user *)head;
+
+		if (get_user(cookie_offset, &head2->cookie_offset))
+			return;
+		if (get_user(pending_cookie, &head2->list_op_pending_cookie))
+			return;
+	}
+
 	/*
 	 * Fetch the list head (which was registered earlier, via
 	 * sys_set_robust_list()):
@@ -1261,7 +1321,11 @@ static void compat_exit_robust_list(struct task_struct *curr)
 		if (entry != pending) {
 			void __user *uaddr = futex_uaddr(entry, futex_offset);
 
-			if (handle_futex_death(uaddr, curr, cur_mod, HANDLE_DEATH_LIST))
+			if (fetch_robust_owner_id(entry, cookies, cookie_offset,
+						  tid, &owner_id))
+				return;
+			if (handle_futex_death(uaddr, curr, cur_mod, HANDLE_DEATH_LIST,
+					       owner_id))
 				return;
 		}
 		if (rc)
@@ -1280,7 +1344,8 @@ static void compat_exit_robust_list(struct task_struct *curr)
 	if (pending) {
 		void __user *uaddr = futex_uaddr(pending, futex_offset);
 
-		handle_futex_death(uaddr, curr, pend_mod, HANDLE_DEATH_PENDING);
+		handle_futex_death(uaddr, curr, pend_mod, HANDLE_DEATH_PENDING,
+				   pending_cookie);
 	}
 }
 
@@ -1419,6 +1484,7 @@ void __futex_fixup_robust_unlock(struct pt_regs *regs, struct futex_unlock_cs_ra
 
 	futex_robust_list_clear_pending(pop, csr->pop_size32 ? FLAGS_ROBUST_LIST32 : 0);
 }
+
 #endif /* CONFIG_FUTEX_ROBUST_UNLOCK */
 
 static void futex_cleanup(struct task_struct *tsk)
@@ -1426,12 +1492,14 @@ static void futex_cleanup(struct task_struct *tsk)
 	if (unlikely(tsk->futex.robust_list)) {
 		exit_robust_list(tsk);
 		tsk->futex.robust_list = NULL;
+		tsk->futex.robust_list_flags = 0;
 	}
 
 #ifdef CONFIG_COMPAT
 	if (unlikely(tsk->futex.compat_robust_list)) {
 		compat_exit_robust_list(tsk);
 		tsk->futex.compat_robust_list = NULL;
+		tsk->futex.compat_robust_list_flags = 0;
 	}
 #endif
 
diff --git a/kernel/futex/futex.h b/kernel/futex/futex.h
index f00f0863ed44..77d7a09fe5b9 100644
--- a/kernel/futex/futex.h
+++ b/kernel/futex/futex.h
@@ -43,6 +43,15 @@
 #define FLAGS_ROBUST_UNLOCK	0x0400
 #define FLAGS_ROBUST_LIST32	0x0800
 
+/*
+ * Kernel internal marker in futex_sched_data::robust_list_flags to
+ * distinguish a registration with struct robust_list_head2 from a
+ * registration with the original struct robust_list_head. Must not
+ * overlap with the UAPI ROBUST_LIST_* flag space.
+ */
+#define FUTEX_RLIST_V2			(1U << 31)
+#define FUTEX_RLIST_VALID_FLAGS		(ROBUST_LIST_COOKIE)
+
 /* FUTEX_ to FLAGS_ */
 static inline unsigned int futex_to_flags(unsigned int op)
 {
diff --git a/kernel/futex/syscalls.c b/kernel/futex/syscalls.c
index 2fa19d9d008d..487326330736 100644
--- a/kernel/futex/syscalls.c
+++ b/kernel/futex/syscalls.c
@@ -24,27 +24,48 @@
  * sys_set_robust_list() - Set the robust-futex list head of a task
  * @head:	pointer to the list-head
  * @len:	length of the list-head, as userspace expects
+ *
+ * Passing sizeof(struct robust_list_head2) as @len registers the extensible
+ * variant of the list head. The additional flags field is validated and
+ * latched at registration time. robust_list_head2::cookie_offset is read at
+ * exit time like robust_list_head::futex_offset.
  */
 SYSCALL_DEFINE2(set_robust_list, struct robust_list_head __user *, head, size_t, len)
 {
-	/* The kernel knows only one size for now. */
-	if (unlikely(len != sizeof(*head)))
-		return -EINVAL;
+	unsigned int rflags = 0;
+
+	if (unlikely(len != sizeof(*head))) {
+		struct robust_list_head2 __user *head2 = (void __user *)head;
+		unsigned long uflags;
+
+		if (len != sizeof(*head2))
+			return -EINVAL;
+		if (get_user(uflags, &head2->flags))
+			return -EFAULT;
+		if (uflags & ~FUTEX_RLIST_VALID_FLAGS)
+			return -EINVAL;
+		rflags = (unsigned int)uflags | FUTEX_RLIST_V2;
+	}
 
 	current->futex.robust_list = head;
+	current->futex.robust_list_flags = rflags;
 	return 0;
 }
 
-static inline void __user *futex_task_robust_list(struct task_struct *p, bool compat)
+static inline void __user *futex_task_robust_list(struct task_struct *p, bool compat,
+						  unsigned int *rflags)
 {
 #ifdef CONFIG_COMPAT
-	if (compat)
+	if (compat) {
+		*rflags = p->futex.compat_robust_list_flags;
 		return p->futex.compat_robust_list;
+	}
 #endif
+	*rflags = p->futex.robust_list_flags;
 	return p->futex.robust_list;
 }
 
-static void __user *futex_get_robust_list_common(int pid, bool compat)
+static void __user *futex_get_robust_list_common(int pid, bool compat, unsigned int *rflags)
 {
 	struct task_struct *p = current;
 	void __user *head;
@@ -71,7 +92,7 @@ static void __user *futex_get_robust_list_common(int pid, bool compat)
 	if (!ptrace_may_access(p, PTRACE_MODE_READ_REALCREDS))
 		goto err_unlock;
 
-	head = futex_task_robust_list(p, compat);
+	head = futex_task_robust_list(p, compat, rflags);
 
 	up_read(&p->signal->exec_update_lock);
 	put_task_struct(p);
@@ -95,12 +116,14 @@ SYSCALL_DEFINE3(get_robust_list, int, pid,
 		struct robust_list_head __user * __user *, head_ptr,
 		size_t __user *, len_ptr)
 {
-	struct robust_list_head __user *head = futex_get_robust_list_common(pid, false);
+	unsigned int rflags = 0;
+	struct robust_list_head __user *head = futex_get_robust_list_common(pid, false, &rflags);
+	size_t len = rflags & FUTEX_RLIST_V2 ? sizeof(struct robust_list_head2) : sizeof(*head);
 
 	if (IS_ERR(head))
 		return PTR_ERR(head);
 
-	if (put_user(sizeof(*head), len_ptr))
+	if (put_user(len, len_ptr))
 		return -EFAULT;
 	return put_user(head, head_ptr);
 }
@@ -481,10 +504,23 @@ SYSCALL_DEFINE4(futex_requeue,
 COMPAT_SYSCALL_DEFINE2(set_robust_list, struct compat_robust_list_head __user *, head,
 		       compat_size_t, len)
 {
-	if (unlikely(len != sizeof(*head)))
-		return -EINVAL;
+	unsigned int rflags = 0;
+
+	if (unlikely(len != sizeof(*head))) {
+		struct compat_robust_list_head2 __user *head2 = (void __user *)head;
+		compat_ulong_t uflags;
+
+		if (len != sizeof(*head2))
+			return -EINVAL;
+		if (get_user(uflags, &head2->flags))
+			return -EFAULT;
+		if (uflags & ~FUTEX_RLIST_VALID_FLAGS)
+			return -EINVAL;
+		rflags = (unsigned int)uflags | FUTEX_RLIST_V2;
+	}
 
 	current->futex.compat_robust_list = head;
+	current->futex.compat_robust_list_flags = rflags;
 	return 0;
