From 302c2f1a3c914f55c429a6a5a8780b995941bb67 Mon Sep 17 00:00:00 2001
From: Keno Fischer <keno@juliahub.com>
Date: Thu, 16 Jul 2026 08:22:51 +0000
Subject: [PATCH 6/8] selftests/futex: Add tests for the VDSO robust cmpxchg
 RSEQ operations

Exercise __vdso_futex_robust_list{64,32}_cmpxchg_rseq():

  - Failure when no RSEQ critical section is armed.

  - Uncontended acquisition: lock word contains the cookie and the
    pending op stays armed for the caller to disarm after queueing the
    entry.

  - Contended failure: pending op is disarmed and the lock word is left
    alone.

  - A signal storm stress test verifying on every iteration that a
    successful return implies the cookie is in the lock word (an abort
    fixup is never applied to a committed operation) and that a failed
    return implies the pending op is disarmed and the free lock word was
    not touched (a stale reservation is never published).

  - A fatal signal stress test for the exit time fixups: children run a
    tight VDSO lock/unlock loop against their registered robust list
    head and are SIGKILLed at pseudo-random points; after every death
    the lock word must be released or marked FUTEX_OWNER_DIED, never
    left owned by the dead child. The critical windows cannot be
    reached deterministically: any ptrace or breakpoint stop inside
    them triggers the RSEQ abort fixup by design, which is exactly why
    the fatal signal path needs the exit time fixups (their necessity
    under identifier reuse is established by the TLA+ model).

The tests register their own rseq TLS area and fall back to the glibc
provided registration via __rseq_offset on libcs which register rseq on
their own.

This series was developed with the assistance of Claude (an AI
assistant by Anthropic); the author reviewed, validated and takes
responsibility for the changes.

Signed-off-by: Keno Fischer <keno@juliahub.com>
---
 .../selftests/futex/functional/robust_list.c  | 521 ++++++++++++++++++
 1 file changed, 521 insertions(+)

diff --git a/tools/testing/selftests/futex/functional/robust_list.c b/tools/testing/selftests/futex/functional/robust_list.c
index 508541010f61..ba19e92f1a94 100644
--- a/tools/testing/selftests/futex/functional/robust_list.c
+++ b/tools/testing/selftests/futex/functional/robust_list.c
@@ -30,6 +30,7 @@
 #include <dlfcn.h>
 #include <errno.h>
 #include <pthread.h>
+#include <sched.h>
 #include <signal.h>
 #include <stdint.h>
 #include <stdatomic.h>
@@ -37,6 +38,7 @@
 #include <stddef.h>
 #include <sys/auxv.h>
 #include <sys/mman.h>
+#include <sys/time.h>
 #include <sys/wait.h>
 
 #define STACK_SIZE (1024 * 1024)
@@ -1750,4 +1752,523 @@ TEST(test_pending_fault)
 	ksft_test_result_pass("%s\n", __func__);
 }
 
+/*
+ * Tests for the RSEQ guarded VDSO lock functions:
+ *
+ *	__vdso_futex_robust_list64_cmpxchg_rseq(u64 *pending_ptr, u64 pending,
+ *						u32 *lock, u32 expect, u32 set,
+ *						struct rseq *rseq)
+ *	__vdso_futex_robust_list32_cmpxchg_rseq(u32 *pending_ptr, u32 pending, ...)
+ */
+
+#define RSEQ_SIG	0x53053053
+
+/*
+ * rseq area owned by the libc-less worker thread (see run_libcless()).
+ * Not __thread: only the single worker thread ever registers or touches
+ * it, so a plain object avoids any dependence on libc TLS.
+ */
+static struct rseq_abi {
+	uint32_t cpu_id_start;
+	uint32_t cpu_id;
+	uint64_t rseq_cs;
+	uint32_t flags;
+} __attribute__((aligned(32))) own_rseq;
+
+struct rseq_cs_abi {
+	uint32_t version;
+	uint32_t flags;
+	uint64_t start_ip;
+	uint64_t post_commit_offset;
+	uint64_t abort_ip;
+} __attribute__((aligned(32)));
+
+/*
+ * An "empty" descriptor: the IP range never contains any executed code,
+ * so any RSEQ event simply clears TLS::rseq::rseq_cs. This is the
+ * "RSEQ event since the descriptor was armed" detector which the VDSO
+ * cmpxchg functions build upon.
+ */
+static const struct rseq_cs_abi empty_cs = {
+	.start_ip = 4096,
+	.post_commit_offset = 0,
+};
+
+/*
+ * Run @fn(@arg) on a "libc-less" thread: a raw clone(CLONE_VM|CLONE_THREAD)
+ * task the C library never set up, so the kernel starts it with rseq ==
+ * NULL and no robust list. It can therefore register and own rseq
+ * regardless of the libc version (modern glibc auto-registers rseq on
+ * every thread it creates, which makes a second registration of a
+ * different rseq area fail with EINVAL). The rseq critical section and the
+ * vDSO cmpxchg must run on the task whose kernel rseq we control, which is
+ * exactly this worker; the caller collects results and asserts on them.
+ * The thread shares the address space and is joined via a
+ * CLONE_CHILD_CLEARTID futex. Returns @fn's value or a negative errno.
+ */
+struct bare_ctx {
+	int (*fn)(void *);
+	void *arg;
+	int ret;
+};
+
+static int bare_entry(void *p)
+{
+	struct bare_ctx *c = p;
+
+	c->ret = c->fn(c->arg);
+	return 0;
+}
+
+static int run_libcless(int (*fn)(void *), void *arg)
+{
+	const size_t sz = 256 * 1024;
+	struct bare_ctx ctx = { fn, arg, 0 };
+	volatile pid_t ctid = 1;
+	char *stack;
+	long tid;
+
+	stack = mmap(NULL, sz, PROT_READ | PROT_WRITE,
+		     MAP_PRIVATE | MAP_ANONYMOUS | MAP_STACK, -1, 0);
+	if (stack == MAP_FAILED)
+		return -errno;
+
+	tid = clone(bare_entry, stack + sz,
+		    CLONE_VM | CLONE_FS | CLONE_FILES | CLONE_SIGHAND |
+		    CLONE_THREAD | CLONE_CHILD_CLEARTID,
+		    &ctx, NULL, NULL, (pid_t *)&ctid);
+	if (tid < 0) {
+		int e = errno;
+
+		munmap(stack, sz);
+		return -e;
+	}
+
+	for (;;) {
+		pid_t v = __atomic_load_n(&ctid, __ATOMIC_ACQUIRE);
+
+		if (!v)
+			break;
+		syscall(SYS_futex, &ctid, FUTEX_WAIT, v, NULL, NULL, 0);
+	}
+	munmap(stack, sz);
+	return ctx.ret;
+}
+
+/* Register @own_rseq on the calling (libc-less) worker. */
+static int worker_register_rseq(void)
+{
+	return syscall(SYS_rseq, &own_rseq, sizeof(own_rseq), 0, RSEQ_SIG);
+}
+
+FIXTURE(vdso_cmpxchg)
+{
+	uint32_t (*vdso)(void *pending_ptr, uint64_t pending, _Atomic(uint32_t) *lock,
+			 uint32_t expect, uint32_t set, volatile struct rseq_abi *rseq);
+	struct rseq_abi *rseq;
+};
+
+FIXTURE_VARIANT(vdso_cmpxchg)
+{
+	const char *vdso_name;
+	bool size32;
+};
+
+FIXTURE_VARIANT_ADD(vdso_cmpxchg, 32)
+{
+	.vdso_name = "__vdso_futex_robust_list32_cmpxchg_rseq",
+	.size32 = true,
+};
+
+#ifdef BUILD_64
+FIXTURE_VARIANT_ADD(vdso_cmpxchg, 64)
+{
+	.vdso_name = "__vdso_futex_robust_list64_cmpxchg_rseq",
+	.size32 = false,
+};
+#endif
+
+FIXTURE_SETUP(vdso_cmpxchg)
+{
+	self->vdso = get_vdso_func_addr(variant->vdso_name);
+	if (!self->vdso)
+		SKIP(return, "%s not found in vDSO", variant->vdso_name);
+
+	/*
+	 * rseq is registered and owned by the libc-less worker thread that
+	 * each test dispatches its rseq/vDSO work to (self->rseq is set
+	 * there); nothing rseq-related runs on this harness thread.
+	 */
+	self->rseq = NULL;
+}
+
+FIXTURE_TEARDOWN(vdso_cmpxchg) {}
+
+/*
+ * Wrappers to invoke the correctly typed function and to check the
+ * pending op state independent of the pointer size.
+ */
+static union {
+	uint64_t u64;
+	uint32_t u32;
+} pend_slot;
+
+static uint32_t do_cmpxchg(FIXTURE_DATA(vdso_cmpxchg) *self,
+			   const FIXTURE_VARIANT(vdso_cmpxchg) *variant,
+			   uint64_t pending, _Atomic(uint32_t) *lock,
+			   uint32_t expect, uint32_t set)
+{
+	if (variant->size32) {
+		uint32_t (*fn)(uint32_t *, uint32_t, _Atomic(uint32_t) *, uint32_t,
+			       uint32_t, volatile struct rseq_abi *) = (void *)self->vdso;
+
+		return fn(&pend_slot.u32, (uint32_t)pending, lock, expect,
+			  set, self->rseq);
+	}
+	return self->vdso(&pend_slot.u64, pending, lock, expect, set, self->rseq);
+}
+
+static uint64_t get_pending(const FIXTURE_VARIANT(vdso_cmpxchg) *variant)
+{
+	if (variant->size32)
+		return pend_slot.u32;
+	return pend_slot.u64;
+}
+
+#define TEST_COOKIE	0x00c0ff33U
+#define TEST_PENDING	0x1000ULL
+
+/*
+ * A single cmpxchg, executed on the libc-less rseq worker: arm rseq_cs to
+ * @arm, run the vDSO helper and report back the return value and the
+ * resulting lock/pending words for the harness thread to assert on.
+ */
+struct cmpxchg_io {
+	FIXTURE_DATA(vdso_cmpxchg) *self;
+	const FIXTURE_VARIANT(vdso_cmpxchg) *variant;
+	uint64_t arm;			/* rseq_cs value to arm before the op */
+	uint64_t pending;
+	uint32_t lock_init;
+	uint32_t expect;
+	uint32_t set;
+	int rseq_ok;
+	uint32_t ret;
+	uint32_t lock_final;
+	uint64_t pending_final;
+};
+
+static int cmpxchg_once(void *p)
+{
+	struct cmpxchg_io *io = p;
+	_Atomic(uint32_t) lock = io->lock_init;
+
+	if (worker_register_rseq()) {
+		io->rseq_ok = 0;
+		return 0;
+	}
+	io->rseq_ok = 1;
+	io->self->rseq = &own_rseq;
+
+	pend_slot.u64 = 0;
+	own_rseq.rseq_cs = io->arm;
+	io->ret = do_cmpxchg(io->self, io->variant, io->pending, &lock,
+			     io->expect, io->set);
+	own_rseq.rseq_cs = 0;
+	io->lock_final = atomic_load(&lock);
+	io->pending_final = get_pending(io->variant);
+	pend_slot.u64 = 0;
+	return 0;
+}
+
+/*
+ * Without an armed rseq_cs the function must fail and leave everything
+ * alone.
+ */
+TEST_F(vdso_cmpxchg, no_rseq_cs)
+{
+	struct cmpxchg_io io = {
+		.self = self, .variant = variant, .arm = 0,
+		.pending = TEST_PENDING, .lock_init = 0, .expect = 0,
+		.set = TEST_COOKIE,
+	};
+
+	ASSERT_EQ(run_libcless(cmpxchg_once, &io), 0);
+	if (!io.rseq_ok)
+		SKIP(return, "Cannot register rseq on the libc-less worker");
+	ASSERT_EQ(io.ret, 0);
+	ASSERT_EQ(io.lock_final, 0);
+	ASSERT_EQ(io.pending_final, 0);
+}
+
+/*
+ * Uncontended acquisition: the lock word gets the cookie and the pending
+ * op stays armed until the caller disarms it.
+ */
+TEST_F(vdso_cmpxchg, uncontended)
+{
+	struct cmpxchg_io io = {
+		.self = self, .variant = variant, .arm = (uintptr_t)&empty_cs,
+		.pending = TEST_PENDING, .lock_init = 0, .expect = 0,
+		.set = TEST_COOKIE,
+	};
+
+	ASSERT_EQ(run_libcless(cmpxchg_once, &io), 0);
+	if (!io.rseq_ok)
+		SKIP(return, "Cannot register rseq on the libc-less worker");
+	ASSERT_EQ(io.ret, 1);
+	ASSERT_EQ(io.lock_final, TEST_COOKIE);
+	ASSERT_EQ(io.pending_final, TEST_PENDING);
+}
+
+/*
+ * Contended lock: the cmpxchg fails, the pending op must be disarmed.
+ */
+TEST_F(vdso_cmpxchg, contended)
+{
+	struct cmpxchg_io io = {
+		.self = self, .variant = variant, .arm = (uintptr_t)&empty_cs,
+		.pending = TEST_PENDING, .lock_init = 0xdead0001, .expect = 0,
+		.set = TEST_COOKIE,
+	};
+
+	ASSERT_EQ(run_libcless(cmpxchg_once, &io), 0);
+	if (!io.rseq_ok)
+		SKIP(return, "Cannot register rseq on the libc-less worker");
+	ASSERT_EQ(io.ret, 0);
+	ASSERT_EQ(io.lock_final, 0xdead0001);
+	ASSERT_EQ(io.pending_final, 0);
+}
+
+static volatile sig_atomic_t sig_count;
+
+static void sigalrm_handler(int sig)
+{
+	sig_count++;
+}
+
+struct stress_io {
+	FIXTURE_DATA(vdso_cmpxchg) *self;
+	const FIXTURE_VARIANT(vdso_cmpxchg) *variant;
+	int rseq_ok;
+	int violated;
+	unsigned long success;
+	unsigned long aborts;
+};
+
+/*
+ * The stress loop runs on the libc-less rseq worker (the task whose rseq
+ * the kernel checks), so it must be the one that receives SIGALRM: the
+ * harness thread blocks SIGALRM before spawning it, and the worker
+ * unblocks it here. Per-iteration invariants are checked inline and folded
+ * into @violated; the harness thread asserts on the summary.
+ */
+static int stress_body(void *p)
+{
+	struct stress_io *io = p;
+	struct itimerval it = {
+		.it_interval = { .tv_usec = 200 },
+		.it_value = { .tv_usec = 200 },
+	};
+	struct sigaction sa = { .sa_handler = sigalrm_handler };
+	_Atomic(uint32_t) lock = 0;
+	sigset_t alrm;
+
+	sigemptyset(&alrm);
+	sigaddset(&alrm, SIGALRM);
+	sigprocmask(SIG_UNBLOCK, &alrm, NULL);
+
+	if (worker_register_rseq()) {
+		io->rseq_ok = 0;
+		return 0;
+	}
+	io->rseq_ok = 1;
+	io->self->rseq = &own_rseq;
+
+	if (sigaction(SIGALRM, &sa, NULL) || setitimer(ITIMER_REAL, &it, NULL))
+		return 1;
+
+	sig_count = 0;
+	while (sig_count < 2000) {
+		uint32_t ret;
+
+		pend_slot.u64 = 0;
+		own_rseq.rseq_cs = (uintptr_t)&empty_cs;
+		ret = do_cmpxchg(io->self, io->variant, TEST_PENDING, &lock, 0,
+				 TEST_COOKIE);
+		own_rseq.rseq_cs = 0;
+
+		if (ret) {
+			io->success++;
+			if (atomic_load(&lock) != TEST_COOKIE ||
+			    get_pending(io->variant) != TEST_PENDING) {
+				io->violated = 1;
+				break;
+			}
+			/* Release the lock */
+			atomic_store(&lock, 0);
+			pend_slot.u64 = 0;
+		} else {
+			io->aborts++;
+			if (get_pending(io->variant) != 0 ||
+			    atomic_load(&lock) != 0) {
+				io->violated = 1;
+				break;
+			}
+		}
+	}
+
+	it.it_interval.tv_usec = 0;
+	it.it_value.tv_usec = 0;
+	setitimer(ITIMER_REAL, &it, NULL);
+	return 0;
+}
+
+/*
+ * Signal storm stress: while SIGALRM fires at high frequency, acquire
+ * and release the lock in a tight loop. Signals landing between arming
+ * rseq_cs and the cmpxchg abort the operation via the kernel fixup.
+ *
+ * Invariants checked on every iteration (see stress_body()):
+ *
+ *  - Success implies the lock word contains the cookie (an abort fixup
+ *    must never be applied to a committed operation).
+ *
+ *  - Failure implies the pending op has been disarmed, and since there
+ *    is no other contender, the lock word must still be free.
+ */
+TEST_F(vdso_cmpxchg, signal_abort_stress)
+{
+	struct stress_io io = { .self = self, .variant = variant };
+	sigset_t alrm, old;
+	int r;
+
+	/* Keep SIGALRM off this thread so it reaches the worker instead. */
+	sigemptyset(&alrm);
+	sigaddset(&alrm, SIGALRM);
+	ASSERT_EQ(sigprocmask(SIG_BLOCK, &alrm, &old), 0);
+
+	r = run_libcless(stress_body, &io);
+	sigprocmask(SIG_SETMASK, &old, NULL);
+
+	ASSERT_EQ(r, 0);
+	if (!io.rseq_ok)
+		SKIP(return, "Cannot register rseq on the libc-less worker");
+	ASSERT_EQ(io.violated, 0);
+	ksft_print_msg("%s: %lu acquisitions, %lu aborts\n", __func__,
+		       io.success, io.aborts);
+	ASSERT_GT(io.success, 0);
+	ASSERT_GT(io.aborts, 0);
+}
+
+/*
+ * Fatal-signal coverage for the exit time fixups of the VDSO critical
+ * windows (an uncommitted cmpxchg and a committed try_unlock with the
+ * pending op still armed). The windows cannot be reached under ptrace:
+ * every stop event inside them triggers the RSEQ abort fixup by design,
+ * which is exactly why only the fatal-signal path needs the exit time
+ * fixups. So this is a stress test: children run a tight VDSO
+ * lock/unlock loop against the *registered* robust list head (both the
+ * signal time and the exit time fixups then operate on the real
+ * list_op_pending slot) and are SIGKILLed at pseudo-random points.
+ * After every death the lock word must be in a recoverable state -
+ * either released or marked FUTEX_OWNER_DIED - never left owned by the
+ * dead child.
+ *
+ * Note the fixups' *necessity* (misattribution after identifier reuse)
+ * is not observable here: it requires a reuse racing the exit walk,
+ * see the TLA+ model. This test provides execution coverage of the
+ * fixup paths and the recoverability guarantee.
+ */
+#define FIXUP_KILL_ITERS	150
+
+struct fixup_kill_region {
+	struct lock_struct2		lock;
+	struct robust_list_head2	head2;
+	_Atomic(int)			ready;
+};
+
+typedef uint32_t (*cmpxchg64_fn)(void *pending_ptr, uint64_t pending,
+				 _Atomic(uint32_t) *lock, uint32_t expect,
+				 uint32_t set, volatile struct rseq_abi *rseq);
+typedef uint32_t (*unlock64_fn)(_Atomic(uint32_t) *lock, uint32_t tid,
+				void *pending_ptr);
+
+static cmpxchg64_fn fixup_kill_cmpxchg;
+static unlock64_fn fixup_kill_unlock;
+
+static int child_fn_fixup_kill(void *arg)
+{
+	struct fixup_kill_region *r = arg;
+	uint64_t entry = (uint64_t)(uintptr_t)&r->lock.list;
+
+	/* A CLONE_VM child starts with no RSEQ registration */
+	if (syscall(SYS_rseq, &own_rseq, sizeof(own_rseq), 0, RSEQ_SIG))
+		return 1;
+	if (set_list2(&r->head2, ROBUST_LIST_COOKIE))
+		return 1;
+	r->head2.list_op_pending_cookie = TEST_COOKIE;
+
+	atomic_store(&r->ready, 1);
+	for (;;) {
+		own_rseq.rseq_cs = (uintptr_t)&empty_cs;
+		if (fixup_kill_cmpxchg(&r->head2.head.list_op_pending, entry,
+				       &r->lock.futex, 0, TEST_COOKIE,
+				       &own_rseq)) {
+			own_rseq.rseq_cs = 0;
+			/*
+			 * Unlock immediately, without queueing the entry:
+			 * this maximizes the density of the two fixup
+			 * windows in the loop.
+			 */
+			fixup_kill_unlock(&r->lock.futex, TEST_COOKIE,
+					  &r->head2.head.list_op_pending);
+		} else {
+			own_rseq.rseq_cs = 0;
+		}
+	}
+	return 0;
+}
+
+TEST(test_vdso_fixup_fatal_signal)
+{
+	struct fixup_kill_region *r;
+	int it, pid, wstatus;
+	unsigned int w;
+
+	fixup_kill_cmpxchg = get_vdso_func_addr("__vdso_futex_robust_list64_cmpxchg_rseq");
+	fixup_kill_unlock = get_vdso_func_addr("__vdso_futex_robust_list64_try_unlock");
+	if (!fixup_kill_cmpxchg || !fixup_kill_unlock)
+		SKIP(return, "VDSO cmpxchg/try_unlock helpers not found");
+
+	r = mmap(NULL, sizeof(*r), PROT_READ | PROT_WRITE,
+		 MAP_SHARED | MAP_ANONYMOUS, -1, 0);
+	ASSERT_NE(r, MAP_FAILED);
+
+	for (it = 0; it < FIXUP_KILL_ITERS; it++) {
+		memset(r, 0, sizeof(*r));
+
+		pid = create_child(child_fn_fixup_kill, r);
+		ASSERT_NE(pid, -1);
+
+		while (!atomic_load(&r->ready))
+			;
+		usleep((it * 37) % 3000);
+		ASSERT_EQ(kill(pid, SIGKILL), 0);
+		ASSERT_EQ(waitpid(pid, &wstatus, 0), pid);
+		ASSERT_TRUE(WIFSIGNALED(wstatus) && WTERMSIG(wstatus) == SIGKILL);
+
+		/*
+		 * The lock must never remain owned by the dead child:
+		 * either it was released (0, potentially with a stale
+		 * WAITERS bit from the kernel wake path) or the exit
+		 * cleanup marked it recoverable.
+		 */
+		w = atomic_load(&r->lock.futex) & ~FUTEX_WAITERS;
+		ASSERT_TRUE(w == 0 || w == FUTEX_OWNER_DIED);
+	}
+
+	munmap(r, sizeof(*r));
+	ksft_test_result_pass("%s\n", __func__);
+}
+
 TEST_HARNESS_MAIN
-- 
