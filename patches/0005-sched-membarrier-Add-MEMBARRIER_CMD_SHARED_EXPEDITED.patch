+	(MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ			\
+	| MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ)
+#else
+#define MEMBARRIER_SHARED_EXPEDITED_RSEQ_BITMASK	0
+#endif
