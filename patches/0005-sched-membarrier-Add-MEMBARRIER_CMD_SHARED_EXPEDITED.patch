 #define MEMBARRIER_CMD_BITMASK						\
 	(MEMBARRIER_CMD_GLOBAL | MEMBARRIER_CMD_GLOBAL_EXPEDITED	\
 	| MEMBARRIER_CMD_REGISTER_GLOBAL_EXPEDITED			\
@@ -162,6 +172,7 @@
 	| MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED			\
 	| MEMBARRIER_PRIVATE_EXPEDITED_SYNC_CORE_BITMASK		\
 	| MEMBARRIER_PRIVATE_EXPEDITED_RSEQ_BITMASK			\
+	| MEMBARRIER_SHARED_EXPEDITED_RSEQ_BITMASK			\
 	| MEMBARRIER_CMD_GET_REGISTRATIONS)
 
 /*
@@ -442,6 +453,179 @@ static int membarrier_private_expedited(int flags, int cpu_id)
 	return 0;
 }
 
+#if defined(CONFIG_RSEQ) && defined(CONFIG_MMU)
+/**
+ * struct membarrier_shared_rseq_walk - rmap walk state for the shared RSEQ fence
+ * @mms:	Snapshot of each online CPU's current task's mm
+ * @cpumask:	Result mask of CPUs which need an RSEQ IPI
+ */
+struct membarrier_shared_rseq_walk {
+	struct mm_struct	**mms;
+	struct cpumask		*cpumask;
+};
+
+static bool membarrier_shared_rseq_rmap_one(struct folio *folio,
+					    struct vm_area_struct *vma,
+					    unsigned long address, void *priv)
+{
+	struct membarrier_shared_rseq_walk *walk = priv;
+	struct mm_struct *mm = vma->vm_mm;
+	int cpu;
+
+	/* Only shared and actually write mapped VMAs are eligible */
+	if ((vma->vm_flags & (VM_SHARED | VM_WRITE)) != (VM_SHARED | VM_WRITE))
+		return true;
+
+	/* Only processes which registered their intent are eligible */
+	if (!(atomic_read(&mm->membarrier_state) &
+	      MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ_READY))
+		return true;
+
+	for_each_online_cpu(cpu) {
+		if (walk->mms[cpu] == mm)
+			__cpumask_set_cpu(cpu, walk->cpumask);
+	}
+
+	return true;
+}
+
+/*
+ * Fence all tasks which are running on other CPUs and have a shared,
+ * writable mapping of the page containing @addr.
+ *
+ * The caller must have the page mapped shared and writable itself, which
+ * confines the reach of this operation to the group of processes which
+ * mutually trust each other with write access to the same memory
+ * anyway. The targets have registered their intent to participate, so
+ * this cannot disturb oblivious processes.
+ */
+static int membarrier_shared_expedited_rseq(unsigned long addr)
+{
+	struct mm_struct *mm = current->mm;
+	struct membarrier_shared_rseq_walk walk;
+	struct rmap_walk_control rwc = {
+		.rmap_one	= membarrier_shared_rseq_rmap_one,
+		.arg		= &walk,
+	};
+	struct mm_struct **mms __free(kfree) = NULL;
+	cpumask_var_t __free(free_cpumask_var) tmpmask = CPUMASK_VAR_NULL;
+	struct folio *folio;
+	struct page *page;
+	long ret;
+	int cpu;
+
+	if (!(atomic_read(&mm->membarrier_state) &
+	      MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ_READY))
+		return -EPERM;
+
+	/*
+	 * Pin the page through the caller's own mapping, which both
+	 * validates that the caller has write access and keeps the folio
+	 * alive across the rmap walk below.
+	 */
+	scoped_guard(mmap_read_lock, mm) {
+		struct vm_area_struct *vma = vma_lookup(mm, addr);
+
+		if (!vma || (vma->vm_flags & (VM_SHARED | VM_WRITE)) !=
+			    (VM_SHARED | VM_WRITE))
+			return -EINVAL;
+
+		ret = get_user_pages(addr, 1, FOLL_WRITE, &page);
+		if (ret != 1)
+			return ret < 0 ? ret : -EFAULT;
+	}
+	folio = page_folio(page);
+
+	mms = kcalloc(nr_cpu_ids, sizeof(*mms), GFP_KERNEL);
+	if (!mms || !zalloc_cpumask_var(&tmpmask, GFP_KERNEL)) {
+		put_page(page);
+		return -ENOMEM;
+	}
+
+	walk.mms = mms;
+	walk.cpumask = tmpmask;
+
+	scoped_guard(mb) {
+		SERIALIZE_IPI();
+		guard(cpus_read_lock)();
+
+		/*
+		 * Snapshot the mm of each online CPU's current task.
+		 *
+		 * The snapshot is compared against the mms of the VMAs
+		 * mapping the pinned folio after the RCU read section
+		 * ends, so a snapshotted mm pointer might already be
+		 * freed and reused by the time it is compared. Such a
+		 * false positive results in a spurious, but harmless,
+		 * RSEQ IPI for whatever runs on that CPU then: the CPU
+		 * was reallocated to a new task through the scheduler,
+		 * which already implies the required RSEQ event and the
+		 * memory barriers.
+		 *
+		 * A task which starts running on a CPU after the
+		 * snapshot equally went through the scheduler after the
+		 * fence started, so skipping it is correct as well.
+		 */
+		scoped_guard(rcu) {
+			for_each_online_cpu(cpu) {
+				struct task_struct *p;
+
+				p = rcu_dereference(cpu_rq(cpu)->curr);
+				if (p && p->mm)
+					walk.mms[cpu] = p->mm;
+			}
+		}
+
+		/*
+		 * Walk all mappings of the pinned folio and collect the
+		 * CPUs which currently run tasks of eligible mms.
+		 */
+		folio_lock(folio);
+		rmap_walk(folio, &rwc);
+		folio_unlock(folio);
+
+		preempt_disable();
+		smp_call_function_many(tmpmask, ipi_rseq, NULL, true);
+		preempt_enable();
+	}
+
+	put_page(page);
+	return 0;
+}
+
+static int membarrier_register_shared_expedited_rseq(void)
+{
+	struct mm_struct *mm = current->mm;
+
+	if (atomic_read(&mm->membarrier_state) &
+	    MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ_READY)
+		return 0;
+	atomic_or(MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ, &mm->membarrier_state);
+
+	/*
+	 * Unlike the other registrations no runqueue state has to be
+	 * updated, as eligibility is solely based on mm::membarrier_state,
+	 * which a concurrent fence reads after the atomic_or() above is
+	 * globally visible: ensure that no memory access following the
+	 * registration is reordered before the registration.
+	 */
+	smp_mb__after_atomic();
+
+	atomic_or(MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ_READY,
+		  &mm->membarrier_state);
+	return 0;
+}
+#else  /* CONFIG_RSEQ && CONFIG_MMU */
+static int membarrier_shared_expedited_rseq(unsigned long addr)
+{
+	return -EINVAL;
+}
+static int membarrier_register_shared_expedited_rseq(void)
+{
+	return -EINVAL;
+}
+#endif /* !(CONFIG_RSEQ && CONFIG_MMU) */
+
 static int sync_runqueues_membarrier_state(struct mm_struct *mm)
 {
 	int membarrier_state = atomic_read(&mm->membarrier_state);
@@ -574,13 +758,16 @@ static int membarrier_get_registrations(void)
 		MEMBARRIER_STATE_PRIVATE_EXPEDITED_SYNC_CORE |
 			MEMBARRIER_STATE_PRIVATE_EXPEDITED_SYNC_CORE_READY,
 		MEMBARRIER_STATE_PRIVATE_EXPEDITED_RSEQ |
-			MEMBARRIER_STATE_PRIVATE_EXPEDITED_RSEQ_READY
+			MEMBARRIER_STATE_PRIVATE_EXPEDITED_RSEQ_READY,
+		MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ |
+			MEMBARRIER_STATE_SHARED_EXPEDITED_RSEQ_READY
 	};
 	static const int registration_cmds[] = {
 		MEMBARRIER_CMD_REGISTER_GLOBAL_EXPEDITED,
 		MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED,
 		MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED_SYNC_CORE,
-		MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED_RSEQ
+		MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED_RSEQ,
+		MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ
 	};
 	BUILD_BUG_ON(ARRAY_SIZE(states) != ARRAY_SIZE(registration_cmds));
 
@@ -606,6 +793,12 @@ static int membarrier_get_registrations(void)
  * @cpu_id: if @flags == MEMBARRIER_CMD_FLAG_CPU, indicates the cpu on which
  *          RSEQ CS should be interrupted (@cmd must be
  *          MEMBARRIER_CMD_PRIVATE_EXPEDITED_RSEQ).
+ * @addr:   for MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ, a user space address
+ *          inside a shared writable mapping of the caller. All processes
+ *          which registered with
+ *          MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ and share a
+ *          writable mapping of the page containing @addr are targeted.
+ *          Ignored by all other commands.
  *
  * If this system call is not implemented, -ENOSYS is returned. If the
  * command specified does not exist, not available on the running
@@ -631,7 +824,8 @@ static int membarrier_get_registrations(void)
  *        smp_mb()           X           O            O
  *        sys_membarrier()   O           O            O
  */
-SYSCALL_DEFINE3(membarrier, int, cmd, unsigned int, flags, int, cpu_id)
+SYSCALL_DEFINE4(membarrier, int, cmd, unsigned int, flags, int, cpu_id,
+		unsigned long, addr)
 {
 	switch (cmd) {
 	case MEMBARRIER_CMD_PRIVATE_EXPEDITED_RSEQ:
@@ -680,6 +874,10 @@ SYSCALL_DEFINE3(membarrier, int, cmd, unsigned int, flags, int, cpu_id)
 		return membarrier_register_private_expedited(MEMBARRIER_FLAG_RSEQ);
 	case MEMBARRIER_CMD_GET_REGISTRATIONS:
 		return membarrier_get_registrations();
+	case MEMBARRIER_CMD_SHARED_EXPEDITED_RSEQ:
+		return membarrier_shared_expedited_rseq(addr);
+	case MEMBARRIER_CMD_REGISTER_SHARED_EXPEDITED_RSEQ:
+		return membarrier_register_shared_expedited_rseq();
 	default:
 		return -EINVAL;
 	}
